generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  jobRole         String
  experienceLevel String
  createdAt       DateTime  @default(now())
  sessions        Session[]
}

model Session {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewType String              @default("behavioral")
  status        String              @default("active") // "active" | "completed"
  startedAt     DateTime            @default(now())
  endedAt       DateTime?
  messages      Message[]
  report        Report?
  experience    ExperienceFeedback?
}

// Candidate's feedback about their interview EXPERIENCE (the AI, tech issues,
// etc.) — reviewed only by the admin. One per session.
model ExperienceFeedback {
  id         String   @id @default(cuid())
  sessionId  String   @unique
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rating     Int // overall experience, 1-5
  aiComment  String   @default("") // how the AI interviewer (Maya) felt
  techIssues String   @default("") // any technical problems faced
  comments   String   @default("") // anything else
  createdAt  DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // "interviewer" | "candidate"
  content   String
  createdAt DateTime @default(now())
}

model Report {
  id        String   @id @default(cuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  data      Json
  createdAt DateTime @default(now())
}
