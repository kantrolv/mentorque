# Postgres connection (Supabase/Neon). Use the pooled/transaction string here.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Direct/session connection (port 5432) used by Prisma for migrations.
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-string"

# Google Gemini API key (free tier) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# Optional: override the model. Defaults to gemini-2.5-flash-lite.
# Switch this if a model's free-tier daily quota is exhausted
# (e.g. gemini-2.5-flash, gemini-2.0-flash).
GEMINI_MODEL="gemini-2.5-flash-lite"

# The deployed frontend origin allowed by CORS (comma-separated for multiple).
CLIENT_ORIGIN="http://localhost:5173"

# Port the server listens on (Render sets this automatically)
PORT=4000
